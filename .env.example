# 复制为 .env 后填写（.env 不会被 git 跟踪）
SECRET_KEY=请替换为随机字符串
ACCESS_TOKEN_EXPIRE_MINUTES=60

MODEL=qwen3.7-plus
DASHSCOPE_API_KEY=sk-your-api-key
DASHSCOPE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

SQLALCHEMY_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_youliao

# 未登录用户聊天限流：窗口内最大请求次数 / 窗口秒数
ANONYMOUS_RATE_LIMIT_MAX=10
ANONYMOUS_RATE_LIMIT_WINDOW=3600
